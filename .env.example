OPENAI_API_KEY=sk-your-api-key-here

# TURN server configuration (required for users behind symmetric NATs/firewalls)
TURN_URL=turn:your-turn-server.example.com:3478
TURNS_URL=turns:your-turn-server.example.com:5349
TURN_USERNAME=your-username
TURN_CREDENTIAL=your-credential

# CORS: comma-separated list of allowed origins (defaults to '*' in development)
ALLOWED_ORIGINS=https://your-app.example.com
