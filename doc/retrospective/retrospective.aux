\@writefile{toc}{\contentsline {subsubsection}{\numberline {2.2.1}Finding a Path: ICE, STUN, and TURN}{8}{subsubsection.2.2.1}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces The NAT problem and how ICE solves it. Top: two browsers behind NATs cannot reach each other directly---neither knows the other's public address. Bottom: STUN discovers each browser's public address; ICE attempts a direct connection (successful 80--90\% of the time) and falls back to a TURN relay when direct connectivity is impossible.}}{9}{figure.2}\protected@file@percent }
\newlabel{fig:nat-ice}{{2}{9}{The NAT problem and how ICE solves it. Top: two browsers behind NATs cannot reach each other directly---neither knows the other's public address. Bottom: STUN discovers each browser's public address; ICE attempts a direct connection (successful 80--90\% of the time) and falls back to a TURN relay when direct connectivity is impossible}{figure.2}{}}
